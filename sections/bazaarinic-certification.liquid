{{ 'bazaarinic-globals.css' | asset_url | stylesheet_tag }}

<style>
  .bz-cert-section {
    background-color: var(--bz-color-dark-bg);
    color: var(--bz-color-dark-text);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  .bz-cert {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 80px;
    align-items: center;
  }
  @media (max-width: 990px) {
    .bz-cert {
      grid-template-columns: 1fr;
      gap: 40px;
      text-align: center;
    }
  }

  .bz-cert__tag {
    color: #38bdf8; /* Clean blue-sky accent */
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    display: inline-block;
    margin-bottom: 16px;
  }
  .bz-cert__title {
    color: #FFFFFF;
    margin-bottom: 24px;
  }
  .bz-cert__text {
    margin-bottom: 36px;
    color: #9CA3AF;
  }

  .bz-cert__badge-container {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  @media (max-width: 480px) {
    .bz-cert__badge-container {
      grid-template-columns: 1fr;
    }
  }
  .bz-cert__badge {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--bz-radius-md);
    padding: 30px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    transition: var(--bz-transition);
  }
  .bz-cert__badge:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.2);
  }
  .bz-cert__badge-icon {
    font-size: 1.75rem;
    font-weight: 800;
    color: #FFFFFF;
    letter-spacing: 1px;
  }
  .bz-cert__badge-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: #9CA3AF;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-align: center;
  }
</style>

<div class="bz-cert-section bz-section">
  <div class="bz-cert">
    
    <!-- Left Column: Copywriting -->
    <div class="bz-cert__content">
      <span class="bz-cert__tag">{{ section.settings.tagline | escape }}</span>
      <h2 class="bz-heading bz-heading-lg bz-cert__title">{{ section.settings.title | escape }}</h2>
      <p class="bz-text bz-text-dark-theme bz-cert__text">{{ section.settings.description | escape }}</p>
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="bz-btn bz-btn--dark">{{ section.settings.button_label | escape }}</a>
      {%- endif -%}
    </div>

    <!-- Right Column: Visual Badges -->
    <div class="bz-cert__badge-container">
      {%- for block in section.blocks -%}
        <div class="bz-cert__badge" {{ block.shopify_attributes }}>
          <span class="bz-cert__badge-icon">{{ block.settings.icon_text | escape }}</span>
          <span class="bz-cert__badge-label">{{ block.settings.label | escape }}</span>
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Bazaarinic Certifications",
  "tag": "section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Official Licensing"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Certified Smart Tech Experience"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Enjoy seamless access to Netflix, Prime Video, and thousands of apps natively, with official Google and Netflix system licensing built right in."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "text",
          "id": "icon_text",
          "label": "Badge Short Text (e.g. NETFLIX, 4K)",
          "default": "4K"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Badge Label",
          "default": "Ultra HD Resolution"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bazaarinic Certifications",
      "blocks": [
        { "type": "badge", "settings": { "icon_text": "NETFLIX", "label": "Official App" } },
        { "type": "badge", "settings": { "icon_text": "4K UHD", "label": "Output Support" } },
        { "type": "badge", "settings": { "icon_text": "DOLBY", "label": "Surround Sound" } }
      ]
    }
  ]
}
{% endschema %}
