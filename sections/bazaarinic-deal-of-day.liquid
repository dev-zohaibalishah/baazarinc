{{ 'bazaarinic-globals.css' | asset_url | stylesheet_tag }}

<style>
  .bz-deal-section {
    padding: 60px 0;
    background-color: var(--bz-color-topbar);
  }
  .bz-deal-container {
    display: flex;
    gap: 40px;
    align-items: center;
  }
  .bz-deal-content {
    flex: 1;
  }
  .bz-deal-image {
    flex: 1;
    text-align: center;
  }
  .bz-deal-title {
    font-size: 36px;
    font-weight: 800;
    color: #222;
    margin-bottom: 20px;
    text-transform: uppercase;
  }
  .bz-deal-desc {
    color: #666;
    margin-bottom: 30px;
    font-size: 16px;
  }
  .bz-countdown {
    display: flex;
    gap: 15px;
    margin-bottom: 30px;
  }
  .bz-time-box {
    background-color: var(--bz-color-accent);
    color: white;
    padding: 15px;
    border-radius: var(--bz-radius-sm);
    text-align: center;
    min-width: 80px;
  }
  .bz-time-num {
    font-size: 24px;
    font-weight: 700;
    display: block;
  }
  .bz-time-label {
    font-size: 12px;
    text-transform: uppercase;
  }
  .bz-deal-price {
    font-size: 32px;
    font-weight: 800;
    color: var(--bz-color-accent);
    margin-bottom: 20px;
  }
  .bz-deal-compare {
    text-decoration: line-through;
    color: #999;
    font-size: 20px;
    margin-left: 10px;
  }
  @media (max-width: 990px) {
    .bz-deal-container {
      flex-direction: column;
    }
  }
</style>

<div class="bz-deal-section">
  <div class="bz-container bz-deal-container">
    <div class="bz-deal-content">
      <h2 class="bz-deal-title">{{ section.settings.title }}</h2>
      <p class="bz-deal-desc">{{ section.settings.description }}</p>
      
      {% assign product = all_products[section.settings.product] %}
      
      {% if product != blank %}
        <div class="bz-deal-price">
          {{ product.price | money }}
          {% if product.compare_at_price > product.price %}
            <span class="bz-deal-compare">{{ product.compare_at_price | money }}</span>
          {% endif %}
        </div>
      {% endif %}
      
      <div class="bz-countdown" data-end-date="{{ section.settings.end_date }}">
        <div class="bz-time-box">
          <span class="bz-time-num" id="bz-days">00</span>
          <span class="bz-time-label">Days</span>
        </div>
        <div class="bz-time-box">
          <span class="bz-time-num" id="bz-hours">00</span>
          <span class="bz-time-label">Hours</span>
        </div>
        <div class="bz-time-box">
          <span class="bz-time-num" id="bz-mins">00</span>
          <span class="bz-time-label">Mins</span>
        </div>
        <div class="bz-time-box">
          <span class="bz-time-num" id="bz-secs">00</span>
          <span class="bz-time-label">Secs</span>
        </div>
      </div>
      
      <a href="{% if product != blank %}{{ product.url }}{% else %}{{ section.settings.button_link }}{% endif %}" class="bz-btn">{{ section.settings.button_label }}</a>
    </div>
    <div class="bz-deal-image">
      {% if product != blank and product.featured_image %}
        <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}" style="max-width: 100%; border-radius: var(--bz-radius-sm);">
      {% else %}
        {{ 'product-2' | placeholder_svg_tag }}
      {% endif %}
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const countdownEl = document.querySelector('.bz-countdown');
    const endDateStr = countdownEl.getAttribute('data-end-date');
    if(!endDateStr) return;
    
    const countDownDate = new Date(endDateStr).getTime();

    const x = setInterval(function() {
      const now = new Date().getTime();
      const distance = countDownDate - now;

      if (distance < 0) {
        clearInterval(x);
        document.getElementById("bz-days").innerHTML = "00";
        document.getElementById("bz-hours").innerHTML = "00";
        document.getElementById("bz-mins").innerHTML = "00";
        document.getElementById("bz-secs").innerHTML = "00";
        return;
      }

      const days = Math.floor(distance / (1000 * 60 * 60 * 24));
      const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((distance % (1000 * 60)) / 1000);

      document.getElementById("bz-days").innerHTML = days < 10 ? '0' + days : days;
      document.getElementById("bz-hours").innerHTML = hours < 10 ? '0' + hours : hours;
      document.getElementById("bz-mins").innerHTML = minutes < 10 ? '0' + minutes : minutes;
      document.getElementById("bz-secs").innerHTML = seconds < 10 ? '0' + seconds : seconds;
    }, 1000);
  });
</script>

{% schema %}
{
  "name": "Bazaarinic Deal of Day",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Deal of the Day"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Grab the latest smart projector with an exclusive discount. Limited time offer!"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Deal Product"
    },
    {
      "type": "text",
      "id": "end_date",
      "label": "End Date",
      "info": "Format: YYYY-MM-DDTHH:MM:SS (e.g., 2026-12-31T23:59:59)",
      "default": "2026-12-31T23:59:59"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link (Fallback)"
    }
  ],
  "presets": [
    {
      "name": "Bazaarinic Deal of Day"
    }
  ]
}
{% endschema %}
