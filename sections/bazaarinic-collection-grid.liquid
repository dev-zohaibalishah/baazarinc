{{ 'bazaarinic-globals.css' | asset_url | stylesheet_tag }}

<style>
  .bz-collection-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: 32px;
  }
  @media (max-width: 768px) {
    .bz-collection-grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
      gap: 16px;
    }
  }
</style>

<div class="bz-section">
  {%- paginate collection.products by section.settings.products_per_page -%}
    <div class="bz-collection-grid">
      {%- for product in collection.products -%}
        <a href="{{ product.url }}" class="bz-card">
          <div class="bz-card__media">
            {%- if product.featured_media -%}
              {{ product.featured_media | image_url: width: 600 | image_tag: loading: 'lazy' }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="bz-card__info">
            {%- if section.settings.show_vendor -%}
              <span class="bz-card__vendor">{{ product.vendor }}</span>
            {%- endif -%}
            <h3 class="bz-card__title">{{ product.title }}</h3>
            <div class="bz-card__price">
              {%- if product.price_varies -%}
                From {{ product.price_min | money }}
              {%- else -%}
                {{ product.price | money }}
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- else -%}
        <p class="bz-text" style="grid-column: 1 / -1; text-align: center;">No products found in this collection.</p>
      {%- endfor -%}
    </div>
    
    {%- if paginate.pages > 1 -%}
      <div style="margin-top: 40px; text-align: center;">
        {{ paginate | default_pagination }}
      </div>
    {%- endif -%}
  {%- endpaginate -%}
</div>

{% schema %}
{
  "name": "Bazaarinic Coll Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 36,
      "step": 4,
      "default": 16,
      "label": "Products per page"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Desktop columns"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2",
      "label": "Mobile columns"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Show vendor"
    }
  ]
}
{% endschema %}
