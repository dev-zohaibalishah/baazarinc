{{ 'bazaarinic-globals.css' | asset_url | stylesheet_tag }}

<style>
  .bz-features {
    display: flex;
    justify-content: space-between;
    border: 1px solid var(--bz-color-border);
    padding: 30px;
    margin: 40px auto;
    border-radius: var(--bz-radius-sm);
  }
  .bz-feature-item {
    display: flex;
    align-items: center;
    gap: 15px;
  }
  .bz-feature-icon {
    width: 40px;
    height: 40px;
    color: var(--bz-color-accent);
  }
  .bz-feature-title {
    font-weight: 700;
    color: #222;
    font-size: 16px;
    margin-bottom: 5px;
    text-transform: uppercase;
  }
  .bz-feature-desc {
    font-size: 13px;
    color: #666;
  }
  @media (max-width: 768px) {
    .bz-features {
      flex-direction: column;
      gap: 20px;
    }
  }
</style>

<div class="bz-container">
  <div class="bz-features">
    {% for block in section.blocks %}
      <div class="bz-feature-item">
        {% if block.settings.custom_svg != blank %}
          <div style="width: 40px; height: 40px; color: var(--bz-color-accent);">{{ block.settings.custom_svg }}</div>
        {% else %}
          <svg class="bz-feature-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
        {% endif %}
        <div>
          <div class="bz-feature-title">{{ block.settings.title }}</div>
          <div class="bz-feature-desc">{{ block.settings.description }}</div>
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Bazaarinic Service",
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 4,
      "settings": [
        {
          "type": "textarea",
          "id": "custom_svg",
          "label": "Custom SVG Code",
          "info": "Paste raw SVG code here"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "On all orders over $99"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bazaarinic Service Features",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Free Shipping",
            "description": "On all orders over $99"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "24/7 Support",
            "description": "Online support 24/7"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Secure Payment",
            "description": "100% secure payment"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Money Back",
            "description": "30 days guarantee"
          }
        }
      ]
    }
  ]
}
{% endschema %}
