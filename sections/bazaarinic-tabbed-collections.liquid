{{ 'bazaarinic-globals.css' | asset_url | stylesheet_tag }}

<style>
  .bz-tabbed {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  .bz-tabbed__header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }
  .bz-tabbed__nav {
    display: flex;
    justify-content: center;
    gap: 16px;
    border-bottom: 1px solid var(--bz-color-border);
    padding-bottom: 12px;
  }
  .bz-tabbed__tab {
    background: none;
    border: none;
    padding: 12px 24px;
    font-size: 1.05rem;
    font-weight: 700;
    color: #6B7280;
    cursor: pointer;
    position: relative;
    transition: var(--bz-transition);
  }
  .bz-tabbed__tab:hover {
    color: var(--bz-color-text);
  }
  .bz-tabbed__tab.is-active {
    color: var(--bz-color-accent);
  }
  .bz-tabbed__tab.is-active::after {
    content: '';
    position: absolute;
    bottom: -13px;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: var(--bz-color-accent);
  }

  .bz-tabbed__content {
    display: none;
  }
  .bz-tabbed__content.is-active {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  @media (max-width: 990px) {
    .bz-tabbed__content.is-active {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
  }
</style>

<div class="bz-section" style="background-color: #FFFFFF;">
  <div class="bz-tabbed">
    
    <div class="bz-tabbed__header">
      <h2 class="bz-heading bz-heading-lg">{{ section.settings.heading | escape }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="bz-text">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>

    <!-- Navigation Tabs -->
    <div class="bz-tabbed__nav">
      {%- for block in section.blocks -%}
        {%- if block.settings.collection != blank -%}
          <button class="bz-tabbed__tab {% if forloop.first %}is-active{% endif %}" data-tab="tab-{{ block.id }}" {{ block.shopify_attributes }}>
            {{ block.settings.collection.title }}
          </button>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Product Grids -->
    {%- for block in section.blocks -%}
      {%- if block.settings.collection != blank -%}
        <div class="bz-tabbed__content {% if forloop.first %}is-active{% endif %}" id="tab-{{ block.id }}">
          {%- for product in block.settings.collection.products limit: 4 -%}
            <a href="{{ product.url }}" class="bz-card">
              <div class="bz-card__media">
                {%- if product.featured_media -%}
                  {{ product.featured_media | image_url: width: 600 | image_tag: loading: 'lazy' }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
              <div class="bz-card__info">
                <span class="bz-card__vendor">{{ product.vendor }}</span>
                <h3 class="bz-card__title">{{ product.title }}</h3>
                <div class="bz-card__price">
                  {%- if product.price_varies -%}
                    From {{ product.price_min | money }}
                  {%- else -%}
                    {{ product.price | money }}
                  {%- endif -%}
                </div>
              </div>
            </a>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endfor -%}

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const tabs = document.querySelectorAll('.bz-tabbed__tab');
    const grids = document.querySelectorAll('.bz-tabbed__content');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        // Remove active class from all tabs
        tabs.forEach(t => t.classList.remove('is-active'));
        // Hide all grids
        grids.forEach(g => g.classList.remove('is-active'));

        // Activate current tab
        tab.classList.add('is-active');
        // Show current grid
        const tabId = tab.getAttribute('data-tab');
        const activeGrid = document.getElementById(tabId);
        if (activeGrid) {
          activeGrid.classList.add('is-active');
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Bazaarinic Tabbed Browser",
  "tag": "section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Browse Innovation"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Instantly switch categories to find the correct gear for your tech environment."
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Collection Tab",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bazaarinic Tabbed Browser",
      "blocks": [
        {
          "type": "tab"
        }
      ]
    }
  ]
}
{% endschema %}
