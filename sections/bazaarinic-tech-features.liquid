{{ 'bazaarinic-globals.css' | asset_url | stylesheet_tag }}

<style>
  .bz-features {
    display: flex;
    flex-direction: column;
    gap: 60px;
  }
  .bz-features__header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }
  .bz-features__header h2 {
    margin-bottom: 16px;
  }
  .bz-features__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: 30px;
  }
  @media (max-width: 768px) {
    .bz-features__grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  .bz-feature-card {
    background-color: var(--bz-color-card);
    border: 1px solid var(--bz-color-border);
    border-radius: var(--bz-radius-md);
    padding: 40px;
    transition: var(--bz-transition);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .bz-feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.05);
    border-color: #D1D5DB;
  }

  .bz-feature-card__icon {
    font-size: 2rem;
    line-height: 1;
    margin-bottom: 24px;
    color: var(--bz-color-accent);
  }
  .bz-feature-card__title {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 12px 0;
    color: var(--bz-color-text);
  }
  .bz-feature-card__description {
    font-size: 0.95rem;
    color: #4B5563;
    line-height: 1.6;
    margin: 0;
  }
</style>

<div class="bz-section" style="background-color: #FFFFFF;">
  <div class="bz-features">
    <div class="bz-features__header">
      <h2 class="bz-heading bz-heading-lg">{{ section.settings.heading | escape }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="bz-text">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>

    <div class="bz-features__grid">
      {%- for block in section.blocks -%}
        <div class="bz-feature-card" {{ block.shopify_attributes }}>
          <span class="bz-feature-card__icon">{{ block.settings.icon | escape }}</span>
          <h3 class="bz-feature-card__title">{{ block.settings.title | escape }}</h3>
          <p class="bz-feature-card__description">{{ block.settings.description | escape }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Bazaarinic Tech Features",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Unrivaled Hardware Engineering"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Explore the next-generation capabilities built inside the Lumex Flix Series."
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "Desktop Columns"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Highlight",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (Emoji)",
          "default": "⚡"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Feature Title",
          "default": "Dolby Atmos Audio"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Feature Description",
          "default": "Envelop your space with multi-directional cinema surround audio."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bazaarinic Tech Features",
      "blocks": [
        { "type": "feature", "settings": { "icon": "🎥", "title": "120-Inch Cinematic projection", "description": "Fill any wall space with massive, bright displays." } },
        { "type": "feature", "settings": { "icon": "🔊", "title": "Dolby Surround Audio", "description": "Crystal clear sound with built-in high fidelity soundstage speakers." } },
        { "type": "feature", "settings": { "icon": "💡", "title": "1000 ANSI Lumens", "description": "Optimized projection contrast, brilliant colors during day or night." } }
      ]
    }
  ]
}
{% endschema %}
