{{ 'bazaarinic-globals.css' | asset_url | stylesheet_tag }}

<style>
  .bz-product-container {
    padding: 60px 0;
  }
  .bz-product-top {
    display: flex;
    gap: 50px;
    margin-bottom: 60px;
  }
  .bz-product-media {
    flex: 1;
  }
  .bz-product-main-img {
    width: 100%;
    border: 1px solid var(--bz-color-border);
    border-radius: var(--bz-radius-md);
    margin-bottom: 15px;
  }
  .bz-product-thumbs {
    display: flex;
    gap: 10px;
  }
  .bz-product-thumb {
    width: 80px;
    height: 80px;
    border: 1px solid var(--bz-color-border);
    border-radius: var(--bz-radius-sm);
    cursor: pointer;
    object-fit: contain;
  }
  .bz-product-thumb.active {
    border-color: var(--bz-color-accent);
  }
  .bz-product-info {
    flex: 1;
  }
  .bz-product-vendor {
    color: var(--bz-color-accent);
    text-transform: uppercase;
    font-weight: 700;
    font-size: 14px;
    margin-bottom: 10px;
  }
  .bz-product-title-main {
    font-size: 32px;
    font-weight: 800;
    color: #222;
    margin-bottom: 20px;
  }
  .bz-product-price-large {
    font-size: 36px;
    color: var(--bz-color-accent);
    font-weight: 800;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 15px;
  }
  .bz-product-compare {
    font-size: 20px;
    color: #999;
    text-decoration: line-through;
  }
  .bz-product-short-desc {
    color: #666;
    font-size: 16px;
    line-height: 1.6;
    margin-bottom: 30px;
    border-bottom: 1px solid var(--bz-color-border);
    padding-bottom: 30px;
  }
  .bz-form-actions {
    display: flex;
    gap: 20px;
    margin-top: 30px;
  }
  .bz-qty-selector {
    display: flex;
    border: 1px solid var(--bz-color-border);
    border-radius: var(--bz-radius-sm);
    overflow: hidden;
  }
  .bz-qty-btn {
    background: #f5f5f5;
    border: none;
    padding: 0 15px;
    font-size: 18px;
    cursor: pointer;
  }
  .bz-qty-input {
    width: 50px;
    text-align: center;
    border: none;
    font-size: 16px;
    font-weight: 600;
  }
  .bz-add-btn {
    flex: 1;
    height: 50px;
    font-size: 18px;
  }
  .bz-buy-btn {
    width: 100%;
    margin-top: 15px;
    height: 50px;
  }
  
  /* Tabs Area */
  .bz-product-tabs-container {
    border: 1px solid var(--bz-color-border);
    border-radius: var(--bz-radius-sm);
    margin-top: 40px;
  }
  .bz-pt-header {
    display: flex;
    border-bottom: 1px solid var(--bz-color-border);
    background: var(--bz-color-topbar);
  }
  .bz-pt-tab {
    padding: 15px 30px;
    font-weight: 700;
    cursor: pointer;
    text-transform: uppercase;
    color: #666;
    border-right: 1px solid var(--bz-color-border);
  }
  .bz-pt-tab.active {
    background: #fff;
    color: var(--bz-color-accent);
    border-bottom: 2px solid var(--bz-color-accent);
    margin-bottom: -1px;
  }
  .bz-pt-content {
    padding: 30px;
    display: none;
    color: #444;
    line-height: 1.8;
  }
  .bz-pt-content.active {
    display: block;
  }
  @media (max-width: 990px) {
    .bz-product-top {
      flex-direction: column;
    }
  }
</style>

<div class="bz-container bz-product-container">
  <div class="bz-product-top">
    <!-- Media Gallery -->
    <div class="bz-product-media">
      {% if product.featured_media %}
        <img src="{{ product.featured_media | image_url: width: 800 }}" alt="{{ product.title | escape }}" class="bz-product-main-img" id="bzMainImg">
      {% endif %}
      <div class="bz-product-thumbs">
        {% for media in product.media %}
          <img src="{{ media | image_url: width: 200 }}" class="bz-product-thumb {% if forloop.first %}active{% endif %}" onclick="document.getElementById('bzMainImg').src='{{ media | image_url: width: 800 }}'; document.querySelectorAll('.bz-product-thumb').forEach(t=>t.classList.remove('active')); this.classList.add('active');">
        {% endfor %}
      </div>
    </div>
    
    <!-- Product Info -->
    <div class="bz-product-info">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'vendor' %}
            <div class="bz-product-vendor">{{ product.vendor }}</div>
          {% when 'title' %}
            <h1 class="bz-product-title-main">{{ product.title }}</h1>
          {% when 'price' %}
            <div class="bz-product-price-large" id="bz-price">
              {{ product.price | money }}
              {% if product.compare_at_price > product.price %}
                <span class="bz-product-compare">{{ product.compare_at_price | money }}</span>
              {% endif %}
            </div>
          {% when 'description' %}
            <div class="bz-product-short-desc">
              {{ product.description | strip_html | truncatewords: 40 }}
            </div>
          {% when 'form' %}
            <form method="post" action="/cart/add" id="add-to-cart-form" enctype="multipart/form-data">
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              
              <!-- Variant Selectors -->
              {% unless product.has_only_default_variant %}
                <div style="margin-bottom: 20px;">
                  {% for option in product.options_with_values %}
                    <div style="margin-bottom: 10px;">
                      <label style="font-weight: 700; display:block; margin-bottom: 5px;">{{ option.name }}</label>
                      <select class="bz-variant-select" style="padding: 10px; width: 100%; max-width: 300px; border: 1px solid var(--bz-color-border);">
                        {% for value in option.values %}
                          <option value="{{ value | escape }}" {% if option.selected_value == value %}selected="selected"{% endif %}>
                            {{ value }}
                          </option>
                        {% endfor %}
                      </select>
                    </div>
                  {% endfor %}
                </div>
              {% endunless %}

              <div class="bz-form-actions">
                <div class="bz-qty-selector">
                  <button type="button" class="bz-qty-btn" onclick="document.getElementById('bz-qty').value = Math.max(1, parseInt(document.getElementById('bz-qty').value)-1)">-</button>
                  <input type="number" id="bz-qty" name="quantity" value="1" min="1" class="bz-qty-input">
                  <button type="button" class="bz-qty-btn" onclick="document.getElementById('bz-qty').value = parseInt(document.getElementById('bz-qty').value)+1">+</button>
                </div>
                <button type="submit" class="bz-btn bz-add-btn">Add to Cart</button>
              </div>
              
              {{ form | payment_button }}
            </form>
        {% endcase %}
      {% endfor %}
    </div>
  </div>
  
  <!-- Product Detailed Tabs -->
  <div class="bz-product-tabs-container">
    <div class="bz-pt-header">
      <div class="bz-pt-tab active" data-target="pt-desc">Description</div>
      <div class="bz-pt-tab" data-target="pt-reviews">Reviews</div>
      <div class="bz-pt-tab" data-target="pt-shipping">Shipping Policy</div>
    </div>
    <div class="bz-pt-content active" id="pt-desc">
      {{ product.description }}
    </div>
    <div class="bz-pt-content" id="pt-reviews">
      <div id="shopify-product-reviews" data-id="{{ product.id }}">{{ product.metafields.spr.reviews }}</div>
      <p>Customer reviews integration area.</p>
    </div>
    <div class="bz-pt-content" id="pt-shipping">
      {{ section.settings.shipping_policy }}
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('.bz-pt-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.bz-pt-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.bz-pt-content').forEach(c => c.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById(tab.getAttribute('data-target')).classList.add('active');
    });
  });
</script>

{% schema %}
{
  "name": "Bazaarinic Main Product",
  "settings": [
    {
      "type": "richtext",
      "id": "shipping_policy",
      "label": "Shipping Policy Tab Content",
      "default": "<p>Free shipping on all orders over $99. Returns accepted within 30 days.</p>"
    }
  ],
  "blocks": [
    { "type": "vendor", "name": "Vendor", "limit": 1 },
    { "type": "title", "name": "Title", "limit": 1 },
    { "type": "price", "name": "Price", "limit": 1 },
    { "type": "description", "name": "Short Description", "limit": 1 },
    { "type": "form", "name": "Buy Buttons", "limit": 1 }
  ]
}
{% endschema %}
