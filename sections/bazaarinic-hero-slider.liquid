{{ 'bazaarinic-globals.css' | asset_url | stylesheet_tag }}

<style>
  .bz-hero-container {
    display: flex;
    gap: 20px;
    margin-top: 20px;
  }
  .bz-hero-slider {
    flex: 3;
    background-color: var(--bz-color-topbar);
    border-radius: var(--bz-radius-sm);
    min-height: 450px;
    display: flex;
    align-items: center;
    padding: 40px;
    position: relative;
    overflow: hidden;
    background-size: cover;
    background-position: center;
  }
  .bz-hero-content {
    max-width: 50%;
    z-index: 2;
  }
  .bz-hero-subtitle {
    color: var(--bz-color-accent);
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 10px;
    letter-spacing: 1px;
  }
  .bz-hero-title {
    font-size: 48px;
    font-weight: 800;
    color: #222;
    margin-bottom: 20px;
    line-height: 1.1;
  }
  .bz-hero-text {
    font-size: 16px;
    color: #666;
    margin-bottom: 30px;
  }
  .bz-hero-banners {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .bz-hero-banner {
    flex: 1;
    background-color: var(--bz-color-topbar);
    border-radius: var(--bz-radius-sm);
    padding: 30px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
    background-size: cover;
    background-position: center;
  }
  .bz-hero-banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(255,255,255,0.9), rgba(255,255,255,0.2));
  }
  .bz-banner-content {
    position: relative;
    z-index: 2;
  }
  .bz-banner-title {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 10px;
    color: #222;
  }
  @media (max-width: 990px) {
    .bz-hero-container {
      flex-direction: column;
    }
  }
</style>

<div class="bz-container">
  <div class="bz-hero-container">
    <!-- Main Slider -->
    <div class="bz-hero-slider" style="{% if section.settings.bg_image %}background-image: url('{{ section.settings.bg_image | image_url: width: 1200 }}');{% endif %}">
      <div class="bz-hero-content">
        <div class="bz-hero-subtitle">{{ section.settings.subtitle }}</div>
        <div class="bz-hero-title" style="color: {{ section.settings.text_color }}">{{ section.settings.title }}</div>
        <div class="bz-hero-text" style="color: {{ section.settings.text_color }}">{{ section.settings.text }}</div>
        <a href="{{ section.settings.btn_link }}" class="bz-btn">{{ section.settings.btn_text }}</a>
      </div>
    </div>
    
    <!-- Side Banners -->
    <div class="bz-hero-banners">
      {% for block in section.blocks %}
        {% if block.type == 'banner' %}
          <div class="bz-hero-banner" style="{% if block.settings.bg_image %}background-image: url('{{ block.settings.bg_image | image_url: width: 400 }}');{% endif %}">
            <div class="bz-banner-content">
              <div class="bz-banner-title">{{ block.settings.title }}</div>
              <a href="{{ block.settings.link }}" style="color: var(--bz-color-accent); font-weight: 700; text-decoration: none;">{{ block.settings.link_text }} -></a>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Bazaarinic Hero Slider",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Big Sale"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "New Smart Tech Collection"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Discover the latest gadgets and electronics."
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#222222"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "banner",
      "name": "Side Banner",
      "limit": 2,
      "settings": [
        {
          "type": "image_picker",
          "id": "bg_image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Smart Watches"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Text",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bazaarinic Hero Slider",
      "blocks": [
        {
          "type": "banner",
          "settings": {
            "title": "Smart Watches"
          }
        },
        {
          "type": "banner",
          "settings": {
            "title": "Security Cameras"
          }
        }
      ]
    }
  ]
}
{% endschema %}
